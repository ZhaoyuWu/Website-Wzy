########################################
# Backend environment template
# Copy to backend/.env for local development.
# For production, set these in your hosting platform env UI.
########################################

# Core server
NODE_ENV=development
PORT=4000

# PostgreSQL (local dev defaults)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=website1st
DB_ADMIN_DB=postgres

# Optional local bootstrap admin (used by db:init when needed)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@nanami.local
# Set explicitly when running db:init if you want bootstrap admin password:
# ADMIN_PASSWORD=change-me

# CORS allowlist (comma-separated)
# Dev example:
CORS_ORIGIN_ALLOWLIST=http://localhost:4200,http://127.0.0.1:4200
# Prod example:
# CORS_ORIGIN_ALLOWLIST=https://your-frontend.vercel.app

# Auth/session tuning (optional)
SESSION_TTL_MS=28800000
LOGIN_ATTEMPT_WINDOW_MS=600000
LOGIN_ATTEMPT_MAX=5
LOGIN_BLOCK_MS=900000

# Supabase (required for media/settings admin APIs)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MEDIA_TABLE=media_items
SUPABASE_STORAGE_BUCKET=media
SUPABASE_ADMIN_MEDIA_LIMIT=60
SUPABASE_SETTINGS_TABLE=site_settings
SUPABASE_SETTINGS_KEY_COLUMN=setting_key
SUPABASE_SETTINGS_ROW_KEY=site
