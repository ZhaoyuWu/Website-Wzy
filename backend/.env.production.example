########################################
# Production example (do NOT commit real secrets)
########################################

NODE_ENV=production
PORT=4000

DB_HOST=your-db-host
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

CORS_ORIGIN_ALLOWLIST=https://your-frontend.vercel.app

SESSION_TTL_MS=28800000
LOGIN_ATTEMPT_WINDOW_MS=600000
LOGIN_ATTEMPT_MAX=5
LOGIN_BLOCK_MS=900000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_MEDIA_TABLE=media_items
SUPABASE_STORAGE_BUCKET=media
SUPABASE_ADMIN_MEDIA_LIMIT=60
SUPABASE_SETTINGS_TABLE=site_settings
SUPABASE_SETTINGS_KEY_COLUMN=setting_key
SUPABASE_SETTINGS_ROW_KEY=site

